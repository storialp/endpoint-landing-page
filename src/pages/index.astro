---
import DnaHelix from "../components/DnaHelix.astro";
import ScrollKaplanSection from "../components/ScrollKaplanSection.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Endpoint</title>
    <meta
      name="description"
      content="Conduct any real-world evidence study in minutes with Endpoint."
    />
  </head>
  <body>
    <main class="page-shell">
      <section class="hero">
        <header class="topbar">
          <a class="brand" href="/" aria-label="Endpoint home">
            <img src="/logo.svg" alt="Endpoint" />
          </a>

          <nav class="nav">
            <a href="/">Blog</a>
            <a href="/">Team</a>
            <a class="cta" href="/">Book a call <span aria-hidden="true">↗</span></a>
          </nav>
        </header>

        <div class="hero-grid">
          <div class="copy-column">
            <p class="eyebrow">
              <span class="eyebrow-dot" aria-hidden="true"></span>
              AI AGENTS FOR REAL-WORLD EVIDENCE
            </p>

            <h1>Conduct any RWE study<span class="headline-break" aria-hidden="true"><br /></span> <span class="headline-tail">in minutes</span></h1>

            <p class="lede">
              Scale evidence generation with our AI-powered platform, delivering instant
              insights from 25M+ multimodal, longitudinal patient records.
            </p>

            <a class="scroll-prompt" href="#learn-more">
              <span class="mouse" aria-hidden="true"><span class="wheel"></span></span>
              <span>SCROLL TO LEARN MORE</span>
            </a>
          </div>

          <div class="visual-column">
            <div class="visual-wrap">
              <DnaHelix />
            </div>
          </div>
        </div>
      </section>

      <section id="learn-more" class="learn-more-anchor" aria-hidden="true"></section>
      <ScrollKaplanSection />
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f7f4ee;
    --surface: rgba(255, 255, 255, 0.7);
    --surface-border: rgba(37, 28, 42, 0.1);
    --ink: #1f1925;
    --muted: #3b3340;
    --accent: #b091ff;
    --eyebrow-bg: #38293c;
    --shadow-soft: 0 24px 80px rgba(43, 28, 55, 0.08);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    font-family: "IBM Plex Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.8), transparent 28%),
      linear-gradient(180deg, #fbf8f2 0%, var(--bg) 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    padding: 2.5rem 4rem 0;
  }

  .hero {
    min-height: 100vh;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.15rem;
    padding: 0.92rem 1.95rem;
    border: 1px solid var(--surface-border);
    border-radius: 1.18rem;
    background: var(--surface);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .brand img {
    display: block;
    width: auto;
    height: 1.85rem;
    max-width: min(13.5rem, 28vw);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-size: 1.12rem;
    font-weight: 500;
  }

  .nav a {
    border-radius: 0.72rem;
    line-height: 1;
    transition:
      transform 180ms ease,
      background-color 180ms ease;
  }

  .nav a:not(.cta) {
    padding: 0.44rem 0.68rem;
    font-size: 1.18rem;
  }

  .nav a:hover {
    transform: translateY(-1px);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.46rem 1rem;
    border-radius: 0.56rem;
    background: var(--accent);
    color: white;
    font-weight: 500;
    font-size: 0.98rem;
    letter-spacing: -0.01em;
  }

  .cta span[aria-hidden="true"] {
    display: inline-block;
    font-size: 1.28rem;
    font-weight: 700;
    line-height: 0.8;
    transform: translateY(-0.03rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(260px, 0.7fr);
    align-items: center;
    gap: 3rem;
    min-height: calc(100vh - 8.5rem);
    padding: 5.7rem 0 2.5rem;
  }

  .copy-column {
    max-width: 58rem;
    padding-left: 0;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0 0 3rem;
    padding: 0.7rem 1.1rem;
    border-radius: 0.65rem;
    background: var(--eyebrow-bg);
    color: #f6eef9;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .eyebrow-dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    background: #ad91ff;
    box-shadow: 0 0 0 0.24rem rgba(173, 145, 255, 0.25);
  }

  h1 {
    margin: 0;
    max-width: 20ch;
    font-size: clamp(3.9rem, 6.15vw, 5.7rem);
    line-height: 0.92;
    font-weight: 300;
    letter-spacing: -0.065em;
  }

  .headline-tail {
    white-space: nowrap;
  }

  .headline-break {
    display: inline;
  }

  .lede {
    margin: 2.5rem 0 0;
    max-width: 50rem;
    color: var(--muted);
    font-size: clamp(1.15rem, 1.75vw, 1.5rem);
    line-height: 1.18;
    letter-spacing: -0.045em;
    font-weight: 300;
  }

  .scroll-prompt {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-top: 10.5rem;
    font-family: "IBM Plex Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 0.95rem;
    font-weight: 300;
    letter-spacing: 0.16em;
  }

  .mouse {
    position: relative;
    width: 1.6rem;
    height: 3.15rem;
    border: 2px solid var(--ink);
    border-radius: 999px;
  }

  .wheel {
    position: absolute;
    top: 0.5rem;
    left: 50%;
    width: 0.28rem;
    height: 0.28rem;
    margin-left: -0.14rem;
    border-radius: 999px;
    background: var(--ink);
    animation: scroll-wheel 2.2s ease-in-out infinite;
  }

  .visual-column {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .visual-wrap {
    width: min(100%, 26rem);
    transform: translate(1.2rem, -0.7rem);
  }

  .learn-more-anchor {
    height: 1px;
  }

  @keyframes scroll-wheel {
    0%,
    100% {
      transform: translate(-50%, 0);
      opacity: 1;
    }

    55% {
      transform: translate(-50%, 1.15rem);
      opacity: 0.25;
    }
  }

  @media (max-width: 1100px) {
    .page-shell {
      padding: 1.6rem 1.25rem 0;
    }

    .hero-grid {
      grid-template-columns: minmax(0, 1.15fr) minmax(200px, 0.85fr);
      gap: 1.5rem;
      align-items: center;
      min-height: auto;
      padding-top: 3.25rem;
      padding-bottom: 3rem;
    }

    .copy-column {
      max-width: none;
    }

    .visual-column {
      order: 0;
      justify-content: flex-end;
      align-self: stretch;
      min-height: 24rem;
    }

    .visual-wrap {
      width: min(100%, 16.5rem);
      margin-right: 0;
      transform: translate(0.5rem, -0.2rem);
    }

    .scroll-prompt {
      margin-top: 5rem;
    }
  }

  @media (max-width: 780px) {
    .page-shell {
      padding: 1rem 0.9rem 0;
    }

    .topbar {
      flex-direction: row;
      align-items: center;
      padding: 0.82rem 1rem;
      gap: 0.8rem;
    }

    .brand {
      justify-content: flex-start;
      min-width: 0;
    }

    .brand img {
      height: 1.45rem;
      max-width: min(9rem, 34vw);
    }

    .nav {
      justify-content: flex-end;
      flex-wrap: nowrap;
      gap: 0.25rem;
      margin-left: auto;
      min-width: 0;
      font-size: 0.98rem;
    }

    .nav a:not(.cta) {
      padding: 0.35rem 0.45rem;
      font-size: 0.98rem;
    }

    .cta {
      gap: 0.3rem;
      padding: 0.52rem 0.8rem;
      font-size: 0.94rem;
      white-space: nowrap;
    }

    .hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(120px, 34vw);
      gap: 1rem;
      min-height: auto;
      padding-top: 2.35rem;
      padding-bottom: 3.5rem;
    }

    .copy-column {
      align-self: start;
    }

    .visual-column {
      justify-content: flex-end;
      align-self: stretch;
      min-height: 25rem;
      padding-top: 1.4rem;
    }

    .visual-wrap {
      width: min(100%, 12rem);
      transform: translate(0.8rem, 0);
    }

    .eyebrow {
      gap: 0.6rem;
      margin-bottom: 2rem;
      padding: 0.65rem 0.95rem;
      font-size: 0.7rem;
      letter-spacing: 0.05em;
    }

    h1 {
      max-width: 7ch;
      font-size: clamp(2.9rem, 9vw, 4.2rem);
      line-height: 0.96;
    }

    .headline-break {
      display: inline;
    }

    .headline-tail {
      white-space: nowrap;
    }

    .lede {
      margin-top: 2rem;
      max-width: 20rem;
      font-size: 1rem;
      line-height: 1.16;
    }

    .scroll-prompt {
      margin-top: 6rem;
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      gap: 0.8rem;
    }

    .mouse {
      width: 1.35rem;
      height: 2.75rem;
    }
  }

  @media (max-width: 560px) {
    .topbar {
      padding: 0.78rem 0.9rem;
    }

    .brand img {
      max-width: min(8rem, 31vw);
    }

    .nav {
      gap: 0.15rem;
    }

    .nav a:not(.cta) {
      padding: 0.3rem 0.35rem;
      font-size: 0.9rem;
    }

    .cta {
      padding: 0.5rem 0.72rem;
      font-size: 0.88rem;
    }

    .hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(104px, 31vw);
      gap: 0.6rem;
      padding-top: 2rem;
    }

    .visual-column {
      min-height: 23rem;
      padding-top: 0.8rem;
    }

    .visual-wrap {
      width: min(100%, 9.75rem);
      transform: translate(0.95rem, 0.25rem);
    }

    h1 {
      max-width: 6ch;
      font-size: clamp(2.65rem, 8.6vw, 3.8rem);
    }

    .lede {
      max-width: 17rem;
      font-size: 0.94rem;
    }

    .scroll-prompt {
      margin-top: 5rem;
    }
  }
</style>
