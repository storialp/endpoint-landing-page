---
import "../styles/global.css";

import DnaHelix from "../components/DnaHelix.astro";
import EndpointNetworkSection from "../components/EndpointNetworkSection.astro";
import EndpointResearchBar from "../components/EndpointResearchBar.astro";
import ScrollKaplanSection from "../components/ScrollKaplanSection.astro";
import UnlockPotentialSection from "../components/UnlockPotentialSection.astro";
import WavyFlowSphere from "../components/WavyFlowSphere.astro";

const tagClass =
  "inline-flex items-center gap-1.5 rounded-full border border-black/5 bg-[#f1f1f0] px-3.5 py-1.5 text-center text-xs text-gray-600";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Endpoint</title>
    <meta
      name="description"
      content="Conduct any real-world evidence study in minutes with Endpoint."
    />
  </head>
  <body>
    <main
      class="[--shell-inline:0.9rem] overflow-x-clip px-[var(--shell-inline)] pt-4 min-[781px]:[--shell-inline:1.25rem] min-[781px]:pt-[1.6rem] min-[1101px]:[--shell-inline:4rem] min-[1101px]:pt-10"
    >
      <section class="min-h-screen">
        <header
          class="flex items-center justify-between gap-3 rounded-[1.18rem] border border-[rgba(37,28,42,0.1)] bg-[rgba(255,255,255,0.7)] px-4 py-[0.82rem] shadow-[inset_0_1px_0_rgba(255,255,255,0.8)] backdrop-blur-[12px] min-[561px]:gap-[1.15rem] min-[561px]:px-[0.9rem] min-[561px]:py-[0.92rem] min-[781px]:px-4 min-[1101px]:px-[1.95rem]"
        >
          <a class="inline-flex shrink-0 items-center min-w-0" href="/" aria-label="Endpoint home">
            <img
              src="/logo.svg"
              alt="Endpoint"
              class="block h-[1.45rem] w-auto max-w-[min(9rem,34vw)] min-[561px]:max-w-[min(8rem,31vw)] min-[781px]:h-[1.85rem] min-[781px]:max-w-[min(13.5rem,28vw)]"
            />
          </a>

          <nav class="ml-auto flex min-w-0 items-center justify-end gap-[0.15rem] text-[0.9rem] font-medium min-[561px]:gap-[0.25rem] min-[781px]:text-[1.12rem] min-[781px]:gap-[0.9rem]">
            <a
              href="/"
              class="rounded-[0.72rem] px-[0.35rem] py-[0.3rem] leading-none transition-transform duration-200 ease-out hover:-translate-y-px min-[561px]:px-[0.45rem] min-[561px]:py-[0.35rem] min-[781px]:px-[0.68rem] min-[781px]:py-[0.44rem] min-[781px]:text-[1.18rem]"
            >
              Blog
            </a>
            <a
              href="/"
              class="rounded-[0.72rem] px-[0.35rem] py-[0.3rem] leading-none transition-transform duration-200 ease-out hover:-translate-y-px min-[561px]:px-[0.45rem] min-[561px]:py-[0.35rem] min-[781px]:px-[0.68rem] min-[781px]:py-[0.44rem] min-[781px]:text-[1.18rem]"
            >
              Team
            </a>
            <a
              href="/"
              class="inline-flex items-center gap-[0.3rem] whitespace-nowrap rounded-[0.56rem] bg-[#b091ff] px-[0.72rem] py-2 text-[0.88rem] leading-none font-medium tracking-[-0.01em] text-white transition-transform duration-200 ease-out hover:-translate-y-px min-[561px]:px-[0.8rem] min-[561px]:py-[0.52rem] min-[561px]:text-[0.94rem] min-[781px]:gap-[0.45rem] min-[781px]:px-4 min-[781px]:py-[0.46rem] min-[781px]:text-[0.98rem]"
            >
              Book a call <span aria-hidden="true" class="text-[1.28rem] leading-[0.8] font-bold">↗</span>
            </a>
          </nav>
        </header>

        <div
          class="grid min-h-auto grid-cols-[minmax(0,1fr)_minmax(104px,31vw)] gap-[0.6rem] py-8 pt-8 min-[561px]:grid-cols-[minmax(0,1fr)_minmax(120px,34vw)] min-[561px]:gap-4 min-[561px]:pt-[2.35rem] min-[561px]:pb-14 min-[781px]:grid-cols-[minmax(0,1.15fr)_minmax(200px,0.85fr)] min-[781px]:gap-6 min-[781px]:pt-[3.25rem] min-[781px]:pb-12 min-[1101px]:min-h-[calc(100vh-8.5rem)] min-[1101px]:grid-cols-[minmax(0,1.3fr)_minmax(260px,0.7fr)] min-[1101px]:gap-12 min-[1101px]:pt-[5.7rem] min-[1101px]:pb-10"
        >
          <div class="max-w-none self-start min-[1101px]:max-w-[58rem]">
            <p
              class="mb-8 inline-flex items-center gap-2 rounded-[0.65rem] bg-[#38293c] px-[0.95rem] py-[0.65rem] text-[0.7rem] font-medium tracking-[0.05em] text-[#f6eef9] min-[781px]:mb-12 min-[781px]:gap-3 min-[781px]:px-[1.1rem] min-[781px]:py-[0.7rem] min-[781px]:text-[0.9rem] min-[781px]:tracking-[0.03em]"
            >
              <span
                class="size-[0.65rem] rounded-full bg-[#ad91ff] shadow-[0_0_0_0.24rem_rgba(173,145,255,0.25)]"
                aria-hidden="true"
              ></span>
              AI AGENTS FOR REAL-WORLD EVIDENCE
            </p>

            <h1
              class="m-0 max-w-[6ch] text-[clamp(2.65rem,8.6vw,3.8rem)] leading-[0.96] font-light tracking-[-0.065em] min-[561px]:max-w-[7ch] min-[561px]:text-[clamp(2.9rem,9vw,4.2rem)] min-[781px]:max-w-none min-[781px]:text-[clamp(3.9rem,6.15vw,5.7rem)] min-[781px]:leading-[0.92] min-[1101px]:max-w-[20ch]"
            >
              Conduct any RWE study<br class="inline" /> <span class="whitespace-nowrap">in minutes</span>
            </h1>

            <p
              class="mt-8 max-w-[17rem] text-[0.94rem] leading-[1.16] font-light tracking-[-0.045em] text-endpoint-muted min-[561px]:max-w-80 min-[561px]:text-base min-[781px]:mt-8 min-[781px]:max-w-[50rem] min-[781px]:text-[clamp(1.15rem,1.75vw,1.5rem)] min-[781px]:leading-[1.18]"
            >
              Scale evidence generation with our AI-powered platform, delivering instant insights
              from 25M+ multimodal, longitudinal patient records.
            </p>

            <a
              class="mt-20 inline-flex items-center gap-3 text-[0.7rem] leading-none font-light tracking-[0.16em] min-[561px]:mt-24 min-[561px]:gap-[0.8rem] min-[781px]:mt-20 min-[781px]:text-[0.95rem] min-[781px]:gap-4 min-[1101px]:mt-[10.5rem]"
              href="#learn-more"
            >
              <span class="relative h-11 w-[1.35rem] rounded-full border-2 border-endpoint-ink min-[781px]:h-[3.15rem] min-[781px]:w-[1.6rem]" aria-hidden="true">
                <span class="scroll-wheel absolute left-1/2 top-2 h-[0.28rem] w-[0.28rem] rounded-full bg-endpoint-ink"></span>
              </span>
              <span>SCROLL TO LEARN MORE</span>
            </a>
          </div>

          <div class="flex min-h-[23rem] items-start justify-end self-stretch pt-0 min-[561px]:min-h-[25rem] min-[781px]:min-h-96 min-[781px]:justify-end min-[1101px]:items-center min-[1101px]:justify-center">
            <div class="w-full translate-x-2 max-w-[9.75rem] min-[561px]:max-w-48 min-[561px]:translate-x-[0.55rem] min-[781px]:max-w-[16.5rem] min-[781px]:translate-x-[0.35rem] min-[1101px]:max-w-[26rem] min-[1101px]:translate-x-5 min-[1101px]:-translate-y-3">
              <DnaHelix />
            </div>
          </div>
        </div>
      </section>

      <section id="learn-more" class="h-px" aria-hidden="true"></section>
      <ScrollKaplanSection />

      <section
        class="[width:calc(100%+(var(--shell-inline)*2))] ml-[calc(var(--shell-inline)*-1)] flex justify-center bg-white px-0 pt-6 min-[781px]:pt-8 min-[1101px]:px-16 min-[1101px]:pt-14"
      >
        <div
          class="relative flex w-full max-w-[1400px] flex-col items-center overflow-hidden rounded-t-[2.1rem] bg-[#1a161f] px-0 pt-11 min-[561px]:rounded-t-[2.5rem] min-[561px]:px-4 min-[561px]:pt-14 min-[1101px]:rounded-t-[60px] min-[1101px]:px-[60px] min-[1101px]:pt-20"
        >
          <h2
            class="mx-auto mb-7 max-w-[11ch] px-4 text-center text-[clamp(2rem,9.8vw,2.75rem)] leading-[0.98] font-normal tracking-[-0.03em] text-white min-[561px]:mb-8 min-[561px]:max-w-[10ch] min-[561px]:text-[clamp(2.35rem,10vw,3.2rem)] min-[781px]:max-w-[9ch] min-[1101px]:mb-10 min-[1101px]:max-w-[13ch] min-[1101px]:px-0 min-[1101px]:text-[42px] min-[1101px]:leading-[1.2]"
          >
            <span class="min-[781px]:block">Enabled via a</span>
            <span class="text-[#b091ff] min-[781px]:block">cutting-edge,</span>
            <span class="text-[#b091ff] min-[781px]:block">user-friendly</span>
            <span class="min-[781px]:block">platform</span>
          </h2>

          <div
            class="flex w-full max-w-none flex-col items-center rounded-t-[1.75rem] bg-white px-4 py-[2.15rem] pb-[1.6rem] shadow-[0_-10px_40px_rgba(0,0,0,0.2)] min-[561px]:rounded-t-[2rem] min-[561px]:px-4 min-[561px]:py-10 min-[1101px]:max-w-[1000px] min-[1101px]:rounded-t-[40px] min-[1101px]:px-[60px] min-[1101px]:py-[60px] min-[1101px]:pb-10"
          >
            <div class="mb-4 size-[min(180px,48vw)] min-[1101px]:mb-[15px] min-[1101px]:size-[180px]">
              <WavyFlowSphere />
            </div>

            <p
              class="mx-auto mb-[1.15rem] max-w-[17ch] text-center text-base leading-[1.15] font-light text-gray-400 text-balance min-[561px]:max-w-[16ch] min-[561px]:text-[1.15rem] min-[1101px]:mb-[30px] min-[1101px]:max-w-[20ch] min-[1101px]:text-lg"
            >
              Evidence begins with a research question
            </p>

            <div class="mb-4 w-full max-w-full px-3 min-[561px]:mb-5 min-[561px]:px-3 min-[1101px]:mb-[30px] min-[1101px]:max-w-[720px] min-[1101px]:px-6">
              <EndpointResearchBar />
            </div>

            <div class="flex flex-wrap justify-center gap-[0.55rem] min-[1101px]:gap-3">
              <span class={tagClass}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 20v-6M9 20v-10M6 20v-4M15 20v-8M18 20V4"></path></svg>
                Comparative effectiveness
              </span>
              <span class={tagClass}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                Real-world outcomes
              </span>
              <span class={tagClass}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 12h18M3 12l4-4M3 12l4 4M21 12l-4-4M21 12l-4 4"></path></svg>
                Label expansion
              </span>
            </div>
          </div>
        </div>
      </section>

      <EndpointNetworkSection />
      <UnlockPotentialSection />

      <footer
        class="[width:calc(100%+(var(--shell-inline)*2))] ml-[calc(var(--shell-inline)*-1)] bg-[#1b151f] px-[1.35rem] py-[1.4rem] text-[rgba(244,239,231,0.86)] min-[781px]:px-[4.8rem] min-[781px]:py-[2rem] min-[781px]:pb-[2.15rem]"
      >
        <p class="m-0 font-mono text-[0.8rem] leading-[1.6] min-[781px]:text-[1.02rem] min-[781px]:leading-[1.5]">
          &copy; Endpoint Data Inc 2025 8 The Green, Ste R Dover, Kent 19901, Delaware, United
          States
        </p>
      </footer>
    </main>
  </body>
</html>
