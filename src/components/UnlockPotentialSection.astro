---
const cardClass =
  "group relative min-h-[10.5rem] overflow-hidden border border-[rgba(255,255,255,0.12)] bg-[linear-gradient(180deg,rgba(255,255,255,0.035),rgba(255,255,255,0.06))] px-[1.15rem] py-[1.3rem] transition-all duration-200 ease-out hover:-translate-y-1 hover:border-[rgba(170,143,255,0.3)] hover:bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.085))] min-[641px]:min-h-[9.5rem] min-[901px]:min-h-[12rem] min-[1201px]:min-h-[9.5rem]";
const titleClass =
  "relative z-[1] m-0 max-w-[10ch] text-[1.08rem] leading-[1.14] font-normal tracking-[-0.04em] text-[#fbf8fd] min-[641px]:text-[clamp(1rem,1.25vw,1.2rem)]";
const visualBase = "pointer-events-none absolute bottom-3 right-[0.85rem] flex items-end justify-end";
---

<section
  class="[width:calc(100%+(var(--shell-inline,0px)*2))] ml-[calc(var(--shell-inline,0px)*-1)] flex min-h-screen items-center px-[var(--shell-inline,4rem)] py-[clamp(3rem,5vw,5rem)] pb-[clamp(4rem,6vw,6rem)] [background:radial-gradient(circle_at_14%_20%,rgba(170,143,255,0.08),transparent_30%),linear-gradient(180deg,#f7f4ee_0%,#f3eee4_100%)] max-[640px]:pt-[4.2rem] max-[640px]:pb-20"
  aria-labelledby="unlock-potential-heading"
>
  <div class="mx-auto grid w-full max-w-[1440px] items-center gap-[clamp(2rem,3vw,3.25rem)] min-[1201px]:grid-cols-[minmax(280px,0.62fr)_minmax(520px,1.38fr)]">
    <div>
      <h2
        id="unlock-potential-heading"
        class="m-0 text-[clamp(2.2rem,10vw,3.4rem)] leading-[0.92] font-light tracking-[-0.07em] text-[#23202a] [font-family:'Helvetica_Neue',Helvetica,Arial,sans-serif] min-[641px]:text-[clamp(2.35rem,4.3vw,4.1rem)] min-[1201px]:max-w-[11ch]"
      >
        That unlocks
        <span class="block text-[#a58aff]">every drug's<br />full potential</span>
      </h2>
    </div>

    <div
      class="unlock-board-shell relative grid grid-cols-1 gap-3 rounded-3xl bg-[linear-gradient(180deg,#220a1e_0%,#180815_100%)] p-4 shadow-[0_40px_80px_rgba(35,11,35,0.18),inset_0_1px_0_rgba(255,255,255,0.04)] [background:radial-gradient(circle_at_15%_10%,rgba(170,143,255,0.08),transparent_28%),linear-gradient(180deg,#220a1e_0%,#180815_100%)] min-[901px]:grid-cols-2 min-[1201px]:grid-cols-3"
      aria-label="Platform capabilities unlocked by Endpoint"
    >
      <article class={cardClass}>
        <h3 class={titleClass}>Map unmet needs</h3>
        <div class:list={[visualBase, "w-14"]}>
          <svg viewBox="0 0 70 70" aria-hidden="true" class="block h-auto w-full">
            <path d="M3.769 35C3.769 17.752 17.752 3.769 35 3.769C52.248 3.769 66.231 17.752 66.231 35C66.231 52.248 52.248 66.231 35 66.231C17.752 66.231 3.769 52.248 3.769 35Z" fill="#D8D8D8"></path>
