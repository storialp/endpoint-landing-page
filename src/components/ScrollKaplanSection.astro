<section
  class="kaplan-section-shell relative isolate mt-8 w-screen max-w-none overflow-clip px-[clamp(1.25rem,4vw,3rem)] py-[clamp(3.5rem,7vw,6rem)] pb-[clamp(5rem,9vw,7rem)] text-[#f4efe6] [margin-left:calc(50%-50vw)] [background:radial-gradient(circle_at_18%_18%,rgba(234,142,94,0.22),transparent_24%),radial-gradient(circle_at_80%_22%,rgba(255,213,145,0.14),transparent_26%),radial-gradient(circle_at_50%_110%,rgba(77,53,103,0.28),transparent_34%),linear-gradient(180deg,#1f1824_0%,#110d15_100%)] max-[640px]:p-0"
  aria-label="Evidence visualization"
>
  <div class="relative h-[320vh] max-[480px]:h-[280vh]" data-kaplan-track>
    <div
      class="kaplan-sticky-shell sticky top-0 z-[1] flex min-h-screen items-center justify-center gap-[clamp(2rem,6vw,8rem)] overflow-clip px-[5vw] py-8 max-[1000px]:flex-col max-[1000px]:gap-12 max-[1000px]:px-6 max-[1000px]:py-16 max-[640px]:min-h-[100svh] max-[640px]:justify-start max-[640px]:gap-0 max-[640px]:px-3 max-[640px]:py-0 max-[480px]:px-2"
      data-kaplan-stage
    >
      <div
        class="relative z-[1] grid flex-1 items-center max-w-[42rem] max-[1000px]:max-w-[34rem] max-[1000px]:justify-items-center max-[1000px]:text-center max-[640px]:min-h-[50svh] max-[640px]:w-full max-[640px]:max-w-none max-[640px]:place-items-center max-[640px]:content-center max-[640px]:py-6"
      >
        <p
          class="kaplan-line col-[1] row-[1] m-0 text-[clamp(2.4rem,4.2vw,4.8rem)] leading-[1.05] font-light tracking-[-0.05em] text-[rgba(244,239,230,0.26)] text-balance max-[640px]:max-w-[12ch] max-[640px]:text-center max-[640px]:text-[clamp(1.55rem,6.6vw,2.45rem)] max-[640px]:leading-[1.08] max-[480px]:max-w-[11ch] max-[480px]:text-[clamp(1.35rem,6vw,2.05rem)]"
          data-copy-primary
        >
          We're creating a future where every medical decision is backed by reliable science.
        </p>
        <p
          class="kaplan-line col-[1] row-[1] m-0 max-w-[22ch] text-[clamp(2.4rem,4.2vw,4.8rem)] leading-[1.05] font-light tracking-[-0.05em] text-[rgba(244,239,230,0.26)] text-balance max-[640px]:max-w-[12ch] max-[640px]:text-center max-[640px]:text-[clamp(1.55rem,6.6vw,2.45rem)] max-[640px]:leading-[1.08] max-[480px]:max-w-[11ch] max-[480px]:text-[clamp(1.35rem,6vw,2.05rem)]"
          data-copy-secondary
        >
          With evidence that is instant, personalized, and accessible.
        </p>
      </div>

      <div
        class="relative z-[1] grid h-[40vw] w-[40vw] shrink-0 place-items-center max-h-[36rem] max-w-[36rem] max-[1000px]:h-auto max-[1000px]:w-full max-[640px]:min-h-[50svh] max-[640px]:w-full"
        data-visual
      >
        <div class="relative grid h-full w-full place-items-center max-[1000px]:size-[min(70vw,30rem)] max-[640px]:size-[min(84vw,21rem)] max-[480px]:size-[min(82vw,19rem)]">
          <div
            class="absolute inset-[10%] z-[1] h-[80%] w-[80%] overflow-hidden rounded-xl bg-[#12141d] opacity-0 shadow-[0_30px_90px_rgba(0,0,0,0.42),0_0_0_1px_rgba(255,226,184,0.08)] [background:radial-gradient(circle_at_50%_18%,rgba(255,214,147,0.08),transparent_30%),#12141d]"
            data-square-mask
          ></div>

          <div
            class="absolute inset-[10%] z-[2] h-[80%] w-[80%] overflow-hidden rounded-xl border border-[rgba(255,239,215,0.14)] bg-[#12141d] opacity-0 shadow-[0_30px_90px_rgba(0,0,0,0.45),inset_0_0_0_1px_rgba(255,255,255,0.04),0_0_40px_rgba(245,113,77,0.08)] [background:radial-gradient(circle_at_50%_18%,rgba(255,214,147,0.08),transparent_30%),#12141d]"
            data-chart-shell
            aria-hidden="true"
          >
            <canvas class="block h-full w-full" data-kaplan-canvas></canvas>
          </div>

          <svg
            class="relative z-[3] h-full w-full overflow-visible"
            viewBox="0 0 100 100"
            preserveAspectRatio="xMidYMid meet"
            aria-hidden="true"
          >
            <defs>
              <linearGradient id="kaplan-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#f5704d"></stop>
                <stop offset="50%" stop-color="#ffcf66"></stop>
                <stop offset="100%" stop-color="#f4efe4"></stop>
              </linearGradient>
            </defs>
            <rect
              data-kaplan-rect
              x="10"
              y="10"
              width="80"
              height="80"
              fill="none"
              stroke="url(#kaplan-gradient)"
              stroke-width="1.2"
              pathLength="1"
              stroke-linecap="square"
            ></rect>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
  const lerp = (start: number, end: number, amount: number) => start + (end - start) * amount;
  const mapRange = (
    value: number,
    inMin: number,
    inMax: number,
    outMin: number,
    outMax: number
  ) => {
    if (inMax === inMin) return outMin;
    const t = clamp((value - inMin) / (inMax - inMin), 0, 1);
    return lerp(outMin, outMax, t);
  };

  const section = document.querySelector("[data-kaplan-track]") as HTMLElement | null;
  if (section) {
    const rect = section.querySelector("[data-kaplan-rect]") as SVGElement | null;
    const mask = section.querySelector("[data-square-mask]") as HTMLElement | null;
    const chartShell = section.querySelector("[data-chart-shell]") as HTMLElement | null;
    const canvas = section.querySelector("[data-kaplan-canvas]") as HTMLCanvasElement | null;
    const primaryCopy = section.querySelector("[data-copy-primary]") as HTMLElement | null;
    const secondaryCopy = section.querySelector("[data-copy-secondary]") as HTMLElement | null;

    interface ChartDataPoint {
      time: number;
      treatment: number;
      control: number;
    }

    const chartData: ChartDataPoint[] = [
      { time: 0, treatment: 1.0, control: 1.0 },
      { time: 1, treatment: 0.985, control: 0.975 },
      { time: 2, treatment: 0.97, control: 0.95 },
      { time: 3, treatment: 0.95, control: 0.915 },
      { time: 4, treatment: 0.93, control: 0.88 },
      { time: 5, treatment: 0.91, control: 0.84 },
      { time: 6, treatment: 0.89, control: 0.8 },
      { time: 7, treatment: 0.865, control: 0.76 },
      { time: 8, treatment: 0.84, control: 0.72 },
      { time: 9, treatment: 0.815, control: 0.685 },
      { time: 10, treatment: 0.79, control: 0.65 },
      { time: 11, treatment: 0.765, control: 0.615 },
      { time: 12, treatment: 0.74, control: 0.58 },
      { time: 13, treatment: 0.715, control: 0.55 },
      { time: 14, treatment: 0.69, control: 0.52 },
      { time: 15, treatment: 0.665, control: 0.49 },
      { time: 16, treatment: 0.64, control: 0.46 },
      { time: 17, treatment: 0.615, control: 0.435 },
      { time: 18, treatment: 0.59, control: 0.41 },
      { time: 19, treatment: 0.57, control: 0.385 },
      { time: 20, treatment: 0.55, control: 0.36 },
      { time: 21, treatment: 0.53, control: 0.34 },
      { time: 22, treatment: 0.51, control: 0.32 },
      { time: 23, treatment: 0.49, control: 0.3 },
      { time: 24, treatment: 0.47, control: 0.28 },
      { time: 25, treatment: 0.45, control: 0.265 },
      { time: 26, treatment: 0.43, control: 0.25 },
      { time: 27, treatment: 0.415, control: 0.235 },
      { time: 28, treatment: 0.4, control: 0.22 },
      { time: 29, treatment: 0.385, control: 0.205 },
      { time: 30, treatment: 0.37, control: 0.19 },
      { time: 31, treatment: 0.355, control: 0.18 },
      { time: 32, treatment: 0.34, control: 0.17 },
      { time: 33, treatment: 0.33, control: 0.16 },
      { time: 34, treatment: 0.32, control: 0.15 },
      { time: 35, treatment: 0.31, control: 0.14 },
      { time: 36, treatment: 0.3, control: 0.13 },
    ];

    let targetProgress = 0;
    let smoothProgress = 0;
    let rafId = 0;
    let chartRevealProgress = 0;
    let scrollVelocity = 0;
    let lastScrollProgress = 0;
    let lastScrollSampleTime = performance.now();

    const CHART_WARMUP_PROGRESS = 0.62;
    const CHART_REVEAL_START = 0.755;
    const CHART_REVEAL_END = 0.94;
    const BASE_FOLLOW_AMOUNT = 0.11;
    const MAX_FOLLOW_AMOUNT = 0.65;
    const VELOCITY_DECAY = 0.9;

    const updateScrollTarget = () => {
      const rectBounds = section.getBoundingClientRect();
      const scrollable = Math.max(section.offsetHeight - window.innerHeight, 1);
      const nextProgress = clamp(-rectBounds.top / scrollable, 0, 1);
      const now = performance.now();
      const elapsed = Math.max(now - lastScrollSampleTime, 16);
      const deltaProgress = Math.abs(nextProgress - lastScrollProgress);
      const instantaneousVelocity = deltaProgress / elapsed;

      scrollVelocity = Math.max(scrollVelocity * 0.72, instantaneousVelocity);
      lastScrollProgress = nextProgress;
      lastScrollSampleTime = now;
      targetProgress = nextProgress;
    };

    const getVelocityBoost = () =>
      clamp(mapRange(scrollVelocity, 0.0004, 0.014, 0, 0.34), 0, 0.34);

    const resizeCanvas = () => {
      if (!canvas || !chartShell) return;
      const dpr = window.devicePixelRatio || 1;
      const width = chartShell.clientWidth;
      const height = chartShell.clientHeight;
      canvas.width = Math.max(1, Math.round(width * dpr));
      canvas.height = Math.max(1, Math.round(height * dpr));
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
    };

    const drawStepCurve = (
      ctx: CanvasRenderingContext2D,
      data: ChartDataPoint[],
      yKey: "treatment" | "control",
      color: string,
      margin: { top: number; right: number; bottom: number; left: number },
      chartWidth: number,
      chartHeight: number,
      maxX: number,
      minY: number,
      lineWidth: number
    ) => {
      if (data.length < 2) return;
      const points = data.map((point) => ({
        x: margin.left + (point.time / maxX) * chartWidth,
        y: margin.top + (chartHeight * (1 - point[yKey])) / (1 - minY),
      }));

      ctx.beginPath();
      ctx.strokeStyle = color;
      ctx.lineWidth = lineWidth;
      ctx.moveTo(points[0].x, points[0].y);

      for (let i = 1; i < points.length; i += 1) {
        ctx.lineTo(points[i].x, points[i - 1].y);
        ctx.lineTo(points[i].x, points[i].y);
      }

      ctx.shadowColor = color;
      ctx.shadowBlur = 1;
      ctx.stroke();
      ctx.shadowBlur = 0;
    };

    const drawChart = (progress: number) => {
      if (!canvas || !chartShell) return;
      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      const dpr = window.devicePixelRatio || 1;
      const width = canvas.width / dpr;
      const height = canvas.height / dpr;

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, width, height);

      const minDimension = Math.min(width, height);
      const axisFontSize = Math.max(9, Math.min(13, minDimension / 28));
      const tickFontSize = Math.max(7, Math.min(11, minDimension / 34));
      const legendFontSize = Math.max(8, Math.min(12, minDimension / 30));

      const margin = {
        top: Math.max(30, height * 0.15),
        right: Math.max(30, width * 0.12),
        bottom: Math.max(60, height * 0.18),
        left: Math.max(60, width * 0.16),
      };

      const chartWidth = width - margin.left - margin.right;
      const chartHeight = height - margin.top - margin.bottom;
      const visiblePoints = Math.max(2, Math.ceil(chartData.length * progress));
      const visibleData = chartData.slice(0, visiblePoints);
      const currentMaxTime = visibleData[visibleData.length - 1].time || 1;

      let currentMinSurvival = 1;
      visibleData.forEach((point) => {
        currentMinSurvival = Math.min(currentMinSurvival, point.treatment, point.control);
      });
      currentMinSurvival = Math.max(0, currentMinSurvival - 0.1);

      ctx.strokeStyle = "rgba(255, 255, 255, 0.1)";
      ctx.lineWidth = 1;

      ctx.beginPath();
      ctx.moveTo(margin.left, height - margin.bottom);
      ctx.lineTo(width - margin.right, height - margin.bottom);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(margin.left, margin.top);
      ctx.lineTo(margin.left, height - margin.bottom);
      ctx.stroke();

      ctx.strokeStyle = "rgba(255, 255, 255, 0.05)";
      const yStep = 0.2;
      for (let i = 0; i <= 1 / yStep; i += 1) {
        const survivalValue = 1 - i * yStep;
        if (survivalValue < currentMinSurvival) break;
        const yPos =
          margin.top +
          (chartHeight * (1 - survivalValue)) / Math.max(1 - currentMinSurvival, 0.001);

        ctx.beginPath();
        ctx.moveTo(margin.left, yPos);
        ctx.lineTo(width - margin.right, yPos);
        ctx.stroke();

        ctx.fillStyle = "rgba(255, 255, 255, 0.5)";
        ctx.font = `${tickFontSize}px "IBM Plex Sans", sans-serif`;
        ctx.textAlign = "right";
        ctx.fillText(`${Math.round(survivalValue * 100)}%`, margin.left - 8, yPos + 3);
      }

      for (let time = 0; time <= currentMaxTime; time += 12) {
        const xPos = margin.left + (chartWidth * time) / Math.max(currentMaxTime, 1);
        ctx.beginPath();
        ctx.moveTo(xPos, margin.top);
        ctx.lineTo(xPos, height - margin.bottom);
        ctx.stroke();

        ctx.fillStyle = "rgba(255, 255, 255, 0.5)";
        ctx.font = `${tickFontSize}px "IBM Plex Sans", sans-serif`;
        ctx.textAlign = "center";
        ctx.fillText(`${time}`, xPos, height - margin.bottom + 16);
      }

      ctx.fillStyle = "rgba(255, 255, 255, 0.8)";
      ctx.font = `${axisFontSize}px "IBM Plex Sans", sans-serif`;
      ctx.textAlign = "center";
      ctx.fillText("Time (Months)", margin.left + chartWidth / 2, height - margin.bottom / 2 + 10);

      ctx.save();
      ctx.translate(margin.left / 2 - 10, margin.top + chartHeight / 2);
      ctx.rotate(-Math.PI / 2);
      ctx.fillText("Survival Probability", 0, 0);
      ctx.restore();

      drawStepCurve(
        ctx,
        visibleData,
        "treatment",
        "#f2a35e",
        margin,
        chartWidth,
        chartHeight,
        currentMaxTime,
        currentMinSurvival,
        2.5
      );
      drawStepCurve(
        ctx,
        visibleData,
        "control",
        "#a391ff",
        margin,
        chartWidth,
        chartHeight,
        currentMaxTime,
        currentMinSurvival,
        2.5
      );

      const legendX = width - margin.right - 100;
      const legendY = margin.top + 10;

      ctx.fillStyle = "#f2a35e";
      ctx.fillRect(legendX, legendY, 12, 3);
      ctx.fillStyle = "rgba(255, 255, 255, 0.8)";
      ctx.font = `${legendFontSize}px "IBM Plex Sans", sans-serif`;
      ctx.textAlign = "left";
      ctx.fillText("Treatment", legendX + 18, legendY + 4);

      ctx.fillStyle = "#a391ff";
      ctx.fillRect(legendX, legendY + 20, 12, 3);
      ctx.fillStyle = "rgba(255, 255, 255, 0.8)";
      ctx.fillText("Control", legendX + 18, legendY + 24);
    };

    const updateChartState = (progress: number) => {
      const revealTarget =
        progress < CHART_WARMUP_PROGRESS
          ? 0
          : mapRange(progress, CHART_REVEAL_START, CHART_REVEAL_END, 0, 1);
      const velocityBoost = getVelocityBoost();
      const revealFollow = clamp(
        0.16 + velocityBoost * 1.35 + Math.abs(revealTarget - chartRevealProgress) * 0.42,
        0.16,
        0.84
      );

      chartRevealProgress = lerp(chartRevealProgress, revealTarget, revealFollow);
      drawChart(chartRevealProgress);
    };

    const render = () => {
      const velocityBoost = getVelocityBoost();
      const followAmount = clamp(
        BASE_FOLLOW_AMOUNT + velocityBoost + Math.abs(targetProgress - smoothProgress) * 0.3,
        BASE_FOLLOW_AMOUNT,
        MAX_FOLLOW_AMOUNT
      );

      smoothProgress = lerp(smoothProgress, targetProgress, followAmount);
      const revealDriverProgress = Math.max(smoothProgress, targetProgress - 0.035);
      updateChartState(revealDriverProgress);
      scrollVelocity *= VELOCITY_DECAY;

      const drawProgress = mapRange(smoothProgress, 0, 0.7, 0, 1);
      const strokeWidth = mapRange(smoothProgress, 0.74, 0.75, 1.2, 0.2);
      const chartOpacity = mapRange(chartRevealProgress, 0, 0.12, 0, 1);
      const maskOpacity = Math.max(
        mapRange(smoothProgress, 0.74, 0.75, 0, 1),
        mapRange(chartRevealProgress, 0, 0.05, 0, 1)
      );
      const copyProgress = Math.max(smoothProgress, targetProgress - 0.03);

      if (rect) {
        rect.style.strokeDasharray = "1";
        rect.style.strokeDashoffset = `${1 - drawProgress}`;
        rect.style.strokeWidth = `${strokeWidth}`;
        rect.style.stroke = revealDriverProgress >= 0.75 ? "#ffffff" : "url(#kaplan-gradient)";
      }
      if (mask) mask.style.opacity = `${maskOpacity}`;
      if (chartShell) chartShell.style.opacity = `${chartOpacity}`;

      if (primaryCopy) {
        primaryCopy.classList.toggle("is-active", copyProgress < 0.74);
        primaryCopy.classList.toggle("is-muted", copyProgress >= 0.74);
        primaryCopy.classList.toggle("is-hidden", copyProgress >= 0.76);
      }
      if (secondaryCopy) {
        secondaryCopy.classList.toggle("is-active", copyProgress >= 0.74);
        secondaryCopy.classList.toggle("is-muted", copyProgress < 0.55);
      }

      rafId = window.requestAnimationFrame(render);
    };

    const onResize = () => {
      updateScrollTarget();
      resizeCanvas();
      drawChart(chartRevealProgress);
    };

    updateScrollTarget();
    resizeCanvas();
    drawChart(0);
    rafId = window.requestAnimationFrame(render);

    window.addEventListener("scroll", updateScrollTarget, { passive: true });
    window.addEventListener("resize", onResize);

    document.addEventListener(
      "astro:before-swap",
      () => {
        window.cancelAnimationFrame(rafId);
        window.removeEventListener("scroll", updateScrollTarget);
        window.removeEventListener("resize", onResize);
      },
      { once: true }
    );
  }
</script>
